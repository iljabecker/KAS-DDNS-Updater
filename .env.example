# KAS API Credentials (from ALL-INKL KAS panel)
KAS_LOGIN=w0XXXXXX
KAS_PASSWORD=dein-kas-passwort

# Komma-getrennte Liste der Domains, deren A-Records aktualisiert werden sollen
KAS_DOMAINS=example.com,sub.example.com

# Optional: Nur bestimmte Record-Namen aktualisieren (leer = alle A-Records der Zone)
KAS_RECORD_NAMES=

# Update-Intervall in Sekunden (Standard: 300 = 5 Minuten)
UPDATE_INTERVAL=300

# Log-Level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
